// NairaInvoice — self-hosted PostgreSQL schema (replaces Supabase)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum InvoiceType {
  invoice
  receipt
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum DiscountType {
  percentage
  fixed
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(USER)
  emailVerified Boolean   @default(false) @map("email_verified")
  emailVerifyToken String? @map("email_verify_token")
  passwordResetToken String? @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  businessProfile   BusinessProfile?
  clients           Client[]
  invoices          Invoice[]
  publicLinks       InvoicePublicLink[]
  onboardingProgress OnboardingProgress?
  refreshTokens     RefreshToken[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model BusinessProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  businessName       String   @map("business_name")
  businessAddress    String?  @map("business_address")
  phone              String?
  email              String?
  logoUrl            String?  @map("logo_url")
  bankName           String?  @map("bank_name")
  accountNumber      String?  @map("account_number")
  accountName        String?  @map("account_name")
  taxId              String?  @map("tax_id")
  invoicePrefix      String   @default("INV") @map("invoice_prefix")
  nextInvoiceNumber  Int      @default(1) @map("next_invoice_number")
  brandAccentColor   String?  @default("#6D28D9") @map("brand_accent_color")
  invoiceFooterText  String?  @default("Generated with Naira Invoice") @map("invoice_footer_text")
  invoiceSignature   String?  @map("invoice_signature")
  invoiceWatermarkText String? @map("invoice_watermark_text")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

model Client {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  clientName    String    @map("client_name")
  clientEmail   String?   @map("client_email")
  clientPhone   String?   @map("client_phone")
  clientAddress String?   @map("client_address")
  notes         String?
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([userId])
  @@index([userId, clientName])
  @@map("clients")
}

model Invoice {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  clientId         String?       @map("client_id") @db.Uuid
  invoiceNumber    String        @map("invoice_number")
  invoiceType      InvoiceType   @map("invoice_type")
  status           InvoiceStatus @default(draft)
  invoiceDate      DateTime      @map("invoice_date") @db.Date
  dueDate          DateTime?     @map("due_date") @db.Date
  subtotal         Decimal       @db.Decimal(12, 2)
  taxPercentage    Decimal?      @map("tax_percentage") @db.Decimal(5, 2)
  taxAmount        Decimal?      @map("tax_amount") @db.Decimal(12, 2)
  discountType     DiscountType? @map("discount_type")
  discountValue    Decimal?      @map("discount_value") @db.Decimal(12, 2)
  discountAmount   Decimal?      @map("discount_amount") @db.Decimal(12, 2)
  totalAmount      Decimal       @map("total_amount") @db.Decimal(12, 2)
  notes            String?
  paymentMethod    String?       @map("payment_method")
  paymentDate      DateTime?     @map("payment_date") @db.Date
  invoiceTemplate  String?       @default("modern_fintech") @map("invoice_template")
  currency         String?       @default("NGN")
  tempClientName   String?       @map("temp_client_name")
  tempClientEmail  String?       @map("temp_client_email")
  tempClientPhone  String?       @map("temp_client_phone")
  tempClientAddress String?      @map("temp_client_address")
  deletedAt        DateTime?     @map("deleted_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items       InvoiceItem[]
  publicLinks InvoicePublicLink[]
  events      InvoiceEvent[]

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(12, 2)
  sortOrder   Int?     @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePublicLink {
  id          String    @id @default(uuid()) @db.Uuid
  invoiceId   String    @map("invoice_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  publicToken String    @unique @map("public_token")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([publicToken])
  @@index([invoiceId])
  @@map("invoice_public_links")
}

model InvoiceEvent {
  id        String   @id @default(uuid()) @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  eventType String   @map("event_type")
  timestamp DateTime @default(now())
  ipHash    String?  @map("ip_hash")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([invoiceId, timestamp(sort: Desc)])
  @@map("invoice_events")
}

model OnboardingProgress {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  profileCompleted Boolean  @default(false) @map("profile_completed")
  clientAdded      Boolean  @default(false) @map("client_added")
  invoiceCreated   Boolean  @default(false) @map("invoice_created")
  wizardDismissed  Boolean  @default(false) @map("wizard_dismissed")
  checklistClosed  Boolean  @default(false) @map("checklist_closed")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}
