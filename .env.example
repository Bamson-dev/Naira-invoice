# Server
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://naira:naira_dev_password@localhost:5432/naira_invoice?schema=public

# Redis (cache + future job queues)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-refresh-openssl-rand-hex-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# File uploads (logos)
UPLOAD_DIR=uploads/logos
MAX_LOGO_BYTES=2097152

# Email (password reset / verification — wire provider later)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@nairainvoice.app
